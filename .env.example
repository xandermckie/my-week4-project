# Copy this file to .env and fill in real values. Never commit .env.

# Anthropic Claude API key — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-flask-secret-key-here

# Fernet encryption key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# Flask environment: development or production
FLASK_ENV=development

# Email (Gmail SMTP) — create a Gmail App Password at myaccount.google.com/apppasswords
# Set MAIL_ENABLED=false to disable email silently without removing config.
MAIL_ENABLED=false
MAIL_USERNAME=contact.ratio.tutor@gmail.com
MAIL_PASSWORD=your-gmail-app-password-here
